#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/ehds/ontology#appliedActivity
:appliedActivity rdf:type owl:ObjectProperty ;
                 owl:inverseOf :isSubjectToObligation ;
                 rdfs:domain :Obligation ;
                 rdfs:range :Activity ;
                 rdfs:comment "Connects a regulatory obligation to the workflow or administrative operation it impacts." ;
                 rdfs:label "appliedActivity" ;
                 skos:definition "To demonstate which obligation applies to a specific activity"@en .


###  https://w3id.org/ehds/ontology#hasAction
:hasAction rdf:type owl:ObjectProperty ;
           rdfs:domain :Obligation ;
           rdfs:range :Actor ;
           rdfs:comment "Triggers an action context from an obligation target vector." ;
           rdfs:label "hasAction" ;
           skos:definition "Links an active obligation statement directly to an actionable target parameter." .


###  https://w3id.org/ehds/ontology#hasCondition
:hasCondition rdf:type owl:ObjectProperty ;
              owl:inverseOf :isConditionFor ;
              rdfs:domain [ rdf:type owl:Class ;
                            owl:unionOf ( :Obligation
                                          :Right
                                        )
                          ] ;
              rdfs:comment "Binds a legal condition to an active boundary, window, or technical perimeter." ;
              rdfs:label "hasCondition" ;
              skos:definition "Links a legal duty or right to a prerequisite state or event that must occur for the"@en .


###  https://w3id.org/ehds/ontology#hasConstraint
:hasConstraint rdf:type owl:ObjectProperty ;
               owl:inverseOf :isConstraintFor ;
               rdfs:domain [ rdf:type owl:Class ;
                             owl:unionOf ( :Obligation
                                           :Right
                                         )
                           ] ;
               rdfs:range :Constraint ;
               rdfs:comment "Binds a legal condition to an active boundary, window, or technical perimeter." ;
               rdfs:label "hasConstraint" ;
               skos:definition "Links a concept to a mandatory regulatory boundary, such as a time limit, geographical bound, or technical threshold."@en .


###  https://w3id.org/ehds/ontology#hasExemption
:hasExemption rdf:type owl:ObjectProperty ;
              owl:inverseOf :isExemptionFor ;
              rdfs:domain :Obligation ;
              rdfs:range :Exception ;
              rdfs:comment "Points to a clause or legislative sub-section that mitigates a standard duty." ;
              rdfs:label "hasExemption" ;
              skos:definition "Used to point from a legal duty to the specific rule that cancels it out"@en .


###  https://w3id.org/ehds/ontology#hasObligation
:hasObligation rdf:type owl:ObjectProperty ;
               owl:inverseOf :isAssignedTo ;
               rdfs:domain :Actor ;
               rdfs:range :Obligation ;
               rdfs:comment "Maps an actor to the legal mandates they are forced to implement." ;
               rdfs:label "hasObligation" ;
               skos:definition "Demonstrates the link between a regulatory actor and an active legal duty."@en .


###  https://w3id.org/ehds/ontology#hasRecipient
:hasRecipient rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              rdfs:comment "Identifies the target party on the receiving end of an entitlement or data transmission payload." ;
              rdfs:label "hasRecipient" ;
              skos:definition "Identifies the entity authorized to receive data or legal notifications from an obligation execution." .


###  https://w3id.org/ehds/ontology#hasRight
:hasRight rdf:type owl:ObjectProperty ;
          owl:inverseOf :isHeldBy ;
          rdfs:domain :Actor ;
          rdfs:range :Right ;
          rdfs:comment "Associates an actor instance to an entitlement or power guaranteed by the EHDS." ;
          rdfs:label "hasRight" ;
          skos:definition "Links a regulatory actor instance directly to a legal right or entitlement." .


###  https://w3id.org/ehds/ontology#isAssignedTo
:isAssignedTo rdf:type owl:ObjectProperty ;
              rdfs:domain :Obligation ;
              rdfs:range :Actor ;
              rdfs:comment "The inverse link declaring which entity carries legal blame or liability for a" ;
              rdfs:label "isAssignedTo" ;
              skos:definition "Designates which concrete entity must fulfill a specific obligation."@en .


###  https://w3id.org/ehds/ontology#isConditionFor
:isConditionFor rdf:type owl:ObjectProperty ;
                rdfs:domain [ rdf:type owl:Class ;
                              owl:unionOf ( :Obligation
                                            :Right
                                          )
                            ] ;
                rdfs:comment "Connects a prerequisite condition to the parent mandate it governs." ;
                rdfs:label "isConditionFor" ;
                skos:definition "Indicates the parent entitlement or mandate that relies on this specific entry trigger." .


###  https://w3id.org/ehds/ontology#isConstraintFor
:isConstraintFor rdf:type owl:ObjectProperty ;
                 rdfs:domain :Constraint ;
                 rdfs:range [ rdf:type owl:Class ;
                              owl:unionOf ( :Obligation
                                            :Right
                                          )
                            ] ;
                 rdfs:comment "The backwards link from an active temporal or spatial limit to its target rules." ;
                 rdfs:label "isConstraintFor" ;
                 skos:definition "Identifies the specific entitlement or duty restricted by this limit."@en .


###  https://w3id.org/ehds/ontology#isExemptionFor
:isExemptionFor rdf:type owl:ObjectProperty ;
                rdfs:domain :Exception ;
                rdfs:range :Obligation ;
                rdfs:comment "Identifies which concrete mandate is overridden by this legislative exemption clause." ;
                rdfs:label "isExemptionFor" ;
                skos:definition "Identifies which specific duty is being waived by this exemption clause."@en .


###  https://w3id.org/ehds/ontology#isHeldBy
:isHeldBy rdf:type owl:ObjectProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Right ;
          rdfs:range :Actor ;
          rdfs:comment "Declares the active legal owner or data subject holding a legislative power." ;
          rdfs:label "isHeldBy" ;
          skos:definition "Designates which individual or corporate entity owns the legal right."@en .


###  https://w3id.org/ehds/ontology#isSubjectToObligation
:isSubjectToObligation rdf:type owl:ObjectProperty ;
                       rdfs:domain :Activity ;
                       rdfs:range :Obligation ;
                       rdfs:comment "Binds a standard compliance task or workflow under a legal mandate constraint." ;
                       rdfs:label "isSubjectToObligation" ;
                       skos:definition "Declares that a compliance activity workflow cannot execute outside the parameters of the attached obligation." .


