@prefix : <https://w3id.org/ehds/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix bibo: <http://purl.org/ontology/bibo/> .

<https://w3id.org/ehds/ontology> rdf:type owl:Ontology, skos:ConceptScheme ;
    owl:versionIRI <https://w3id.org/ehds/ontology/1.0.0> ;
    owl:versionInfo "1.0.0" ;
    dcterms:title "European Health Data Space (EHDS) Compliance Ontology"@en ;
    dcterms:description "A compliance-focused ontology mapping out actors, roles, legal rights, and structural obligations within the European Health Data Space (EHDS) framework."@en ;
    dcterms:created "2026-02-15"^^xsd:date ;
    dcterms:issued "2026-03-01"^^xsd:date ;
    dcterms:modified "2026-06-19"^^xsd:date ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:creator [ foaf:name "Gabriela Kurteva" ] ;
    dcterms:contributor [ foaf:name "Gabriela Kurteva" ] ;
    dcterms:publisher [ foaf:name "W3C European Health Data Space Community Group" ] ;
    dcterms:identifier "https://doi.org/10.5281/zenodo.ehds.ontology.v1" ;
    dcterms:bibliographicCitation "Kurteva, G. (2026). European Health Data Space (EHDS) Compliance Ontology. w3id Semantic Web Repository."@en ;
    bibo:status "Stable" ;
    foaf:logo <https://w3id.org/ehds/ontology/assets/logo.png> ;
    vann:preferredNamespacePrefix "ehds" ;
    vann:preferredNamespaceUri "https://w3id.org/ehds/ontology#" ;
    
    # ---- RDF/SKOS ALIGNED METADATA FIXED FOR OM3 ----
    dcterms:source <https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:52022PC0197> ;
    dcterms:replaces <https://w3id.org/ehds/ontology/0.9.0> .

:sh:property rdf:type owl:AnnotationProperty ;
    rdfs:label "SHACL property constraint annotation"@en ;
    rdfs:comment "Specifies the link between a shape and its target property restrictions inside validation rules."@en .

:sh:targetClass rdf:type owl:AnnotationProperty ;
    rdfs:label "SHACL target class annotation"@en ;
    rdfs:comment "Binds a SHACL validation shape to all structural instances of a target class layer."@en .

skos:broader rdf:type owl:AnnotationProperty ;
    rdfs:label "has broader concept"@en ;
    rdfs:comment "Relates a specific regulatory article or node backward to its broader concept parent."@en .

skos:definition rdf:type owl:AnnotationProperty ;
    rdfs:label "definition"@en ;
    rdfs:comment "Provides a human-readable legal deconstruction or description of the concept."@en .

skos:prefLabel rdf:type owl:AnnotationProperty ;
    rdfs:label "preferred label"@en ;
    rdfs:comment "The primary human-readable textual descriptor or label for the vocabulary element."@en .

skos:inScheme rdf:type owl:AnnotationProperty ;
    rdfs:label "is in concept scheme"@en ;
    rdfs:comment "Declares the global Concept Scheme container that manages this legal term instance."@en .

:appliedActivity rdf:type owl:ObjectProperty ;
    owl:inverseOf :isSubjectToObligation ;
    rdfs:domain :Obligation ;
    rdfs:range :Activity ;
    rdfs:label "appliedActivity"@en ;
    rdfs:comment "Connects a regulatory obligation to the workflow or administrative operation it impacts."@en ;
    skos:definition "Demonstrates which obligation applies to a specific legal activity."@en .

:hasAction rdf:type owl:ObjectProperty ;
    rdfs:domain :Obligation ;
    rdfs:range :Actor ;
    rdfs:label "hasAction"@en ;
    rdfs:comment "Triggers an action context from an obligation target vector."@en ;
    skos:definition "Links an active obligation statement directly to an actionable target parameter."@en .

:hasCondition rdf:type owl:ObjectProperty ;
    owl:inverseOf :isConditionFor ;
    rdfs:domain [ rdf:type owl:Class ; owl:unionOf ( :Obligation :Right ) ] ;
    rdfs:label "hasCondition"@en ;
    rdfs:comment "Links a right or duty to its prerequisite administrative triggers."@en ;
    skos:definition "Links a legal duty or right to a prerequisite state or event that must occur for the rule to activate."@en .

:hasConstraint rdf:type owl:ObjectProperty ;
    owl:inverseOf :isConstraintFor ;
    rdfs:domain [ rdf:type owl:Class ; owl:unionOf ( :Obligation :Right ) ] ;
    rdfs:range :Constraint ;
    rdfs:label "hasConstraint"@en ;
    rdfs:comment "Binds a legal condition to an active boundary, window, or technical perimeter."@en ;
    skos:definition "Links a concept to a mandatory regulatory boundary, such as a time limit, geographical bound, or technical threshold."@en .

:hasExemption rdf:type owl:ObjectProperty ;
    owl:inverseOf :isExemptionFor ;
    rdfs:domain :Obligation ;
    rdfs:range :Exception ;
    rdfs:label "hasExemption"@en ;
    rdfs:comment "Points to a clause or legislative sub-section that mitigates a standard duty."@en ;
    skos:definition "Used to point from a legal duty to the specific rule that waives or exempts it."@en .

:hasObligation rdf:type owl:ObjectProperty ;
    owl:inverseOf :isAssignedTo ;
    rdfs:domain :Actor ;
    rdfs:range :Obligation ;
    rdfs:label "hasObligation"@en ;
    rdfs:comment "Maps an actor to the legal mandates they are forced to implement."@en ;
    skos:definition "Demonstrates the link between a regulatory actor and an active legal duty."@en .

:hasRecipient rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:label "hasRecipient"@en ;
    rdfs:comment "Identifies the target party on the receiving end of an entitlement or data transmission payload."@en ;
    skos:definition "Identifies the entity authorized to receive data or legal notifications from an obligation execution."@en .

:hasRight rdf:type owl:ObjectProperty ;
    owl:inverseOf :isHeldBy ;
    rdfs:domain :Actor ;
    rdfs:range :Right ;
    rdfs:label "hasRight"@en ;
    rdfs:comment "Associates an actor instance to an entitlement or power guaranteed by the EHDS."@en ;
    skos:definition "Links a regulatory actor instance directly to a legal right or entitlement."@en .

:isAssignedTo rdf:type owl:ObjectProperty ;
    rdfs:domain :Obligation ;
    rdfs:range :Actor ;
    rdfs:label "isAssignedTo"@en ;
    rdfs:comment "The inverse link declaring which entity carries legal blame or liability for a mandate."@en ;
    skos:definition "Designates which concrete entity must fulfill a specific obligation."@en .

:isConditionFor rdf:type owl:ObjectProperty ;
    rdfs:domain [ rdf:type owl:Class ; owl:unionOf ( :Obligation :Right ) ] ;
    rdfs:label "isConditionFor"@en ;
    rdfs:comment "Connects a prerequisite condition to the parent mandate it governs."@en ;
    skos:definition "Indicates the parent entitlement or mandate that relies on this specific entry trigger."@en .

:isConstraintFor rdf:type owl:ObjectProperty ;
    rdfs:domain :Constraint ;
    rdfs:range [ rdf:type owl:Class ; owl:unionOf ( :Obligation :Right ) ] ;
    rdfs:label "isConstraintFor"@en ;
    rdfs:comment "The backwards link from an active temporal or spatial limit to its target rules."@en ;
    skos:definition "Identifies the specific entitlement or duty restricted by this limit."@en .

:isExemptionFor rdf:type owl:ObjectProperty ;
    rdfs:domain :Exception ;
    rdfs:range :Obligation ;
    rdfs:label "isExemptionFor"@en ;
    rdfs:comment "Identifies which concrete mandate is overridden by this legislative exemption clause."@en ;
    skos:definition "Identifies which specific duty is being waived by this exemption clause."@en .

:isHeldBy rdf:type owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain :Right ;
    rdfs:range :Actor ;
    rdfs:label "isHeldBy"@en ;
    rdfs:comment "Declares the active legal owner or data subject holding a legislative power."@en ;
    skos:definition "Designates which individual or corporate entity owns the legal right."@en .

:isSubjectToObligation rdf:type owl:ObjectProperty ;
    rdfs:domain :Activity ;
    rdfs:range :Obligation ;
    rdfs:label "isSubjectToObligation"@en ;
    rdfs:comment "Binds a standard compliance task or workflow under a legal mandate constraint."@en ;
    skos:definition "Declares that a compliance activity workflow cannot execute outside the parameters of the attached obligation."@en .


:Activity rdf:type owl:Class ; rdfs:label "Activity"@en ; rdfs:comment "An active process, processing operation, or statutory workflow."@en .
:Entity rdf:type owl:Class ; rdfs:label "Entity"@en ; rdfs:comment "A generic foundational class for any actor, body, object, or legal construct."@en .
:Obligation rdf:type owl:Class ; rdfs:label "Obligation"@en ; rdfs:comment "A legal duty, command, or mandate that must be executed by an assigned actor."@en .
:Right rdf:type owl:Class ; rdfs:label "Right"@en ; rdfs:comment "A legal power, capability, or active entitlement held by a data subject or body."@en .
:Requirement rdf:type owl:Class ; rdfs:label "Requirement"@en ; rdfs:comment "A condition, constraint, or structural criteria that governs an execution framework."@en .
:Actor rdf:type owl:Class ; rdfs:subClassOf :Entity ; rdfs:label "Actor"@en ; rdfs:comment "An agent or structural participant executing tasks or holding rights within the EHDS."@en .
:Authority rdf:type owl:Class ; rdfs:subClassOf :GovernmentalOrganisation ; rdfs:label "Authority"@en ; rdfs:comment "A public body or supervisory entity tasked with administrative oversight."@en .
:Condition rdf:type owl:Class ; rdfs:subClassOf :Requirement ; rdfs:label "Condition"@en ; rdfs:comment "A legal prerequisite that must be validated to trigger an active status."@en .
:Constraint rdf:type owl:Class ; rdfs:subClassOf :Requirement ; rdfs:label "Constraint"@en ; rdfs:comment "A limit, such as a spatial ceiling or clear time window boundary."@en .
:Exception rdf:type owl:Class ; rdfs:subClassOf :Requirement ; rdfs:label "Exception"@en ; rdfs:comment "A legislative waiver that voids or mitigates a baseline statutory mandate."@en .
:Organisation rdf:type owl:Class ; rdfs:label "Organisation"@en ; rdfs:comment "An incorporated collective, business entity, group, or public body."@en .
:GovernmentalOrganisation rdf:type owl:Class ; rdfs:subClassOf :Organisation ; rdfs:label "GovernmentalOrganisation"@en ; rdfs:comment "An branch of public administration or state oversight infrastructure."@en .
:Non-ProfitOrganisation rdf:type owl:Class ; rdfs:subClassOf :Organisation ; rdfs:label "Non-ProfitOrganisation"@en ; rdfs:comment "A civil or charity collective operating outside corporate profit vectors."@en .
:LegalEntity rdf:type owl:Class ; rdfs:subClassOf :Entity ; rdfs:label "LegalEntity"@en ; rdfs:comment "An individual or corporate body recognized in law as having rights and duties."@en .
:HumanSubject rdf:type owl:Class ; rdfs:subClassOf :LegalEntity ; rdfs:label "HumanSubject"@en ; rdfs:comment "A living natural person or data subject within the scope of digital health rules."@en .
:Representative rdf:type owl:Class ; rdfs:label "Representative"@en ; rdfs:comment "A proxy agent legally designated to act on behalf of a manufacturer or patient."@en .
:NationalAuthority rdf:type owl:Class ; rdfs:subClassOf :Authority ; rdfs:label "NationalAuthority"@en ; rdfs:comment "A public oversight body localized within a distinct EU Member State."@en .
:SupraNational rdf:type owl:Class ; rdfs:label "SupraNational"@en ; rdfs:comment "An entity operating across state borders at the union layer, such as the European Commission."@en .
:TechnologyImporter rdf:type owl:Class ; rdfs:subClassOf :Actor ; rdfs:label "TechnologyImporter"@en ; rdfs:comment "An agent importing medical data software systems from a third country into the EU market."@en .
:TechnologyImporterObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "TechnologyImporterObligation"@en ; rdfs:comment "Explicit mandates governing data software importers."@en .

:AISystemProvider rdf:type owl:Class ;
    rdfs:subClassOf :Actor , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :AISystemProviderObligation ] ;
    rdfs:label "AISystemProvider"@en ;
    rdfs:comment "An enterprise that manufactures or deploys AI models within the digital health space."@en .

:AISystemProviderObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "AISystemProviderObligation"@en ; rdfs:comment "Legal duties levied on AI model providers under the EHDS framework."@en .
:Controller rdf:type owl:Class ; rdfs:subClassOf :LegalEntity ; rdfs:label "Controller"@en ; rdfs:comment "The entity determining the core purpose and structural processing vectors of health datasets."@en .
:ControllerObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "ControllerObligation"@en ; rdfs:comment "A specific mandate governing compliance vectors for a data controller."@en .

:DataAltruismOrganisation rdf:type owl:Class ;
    rdfs:subClassOf :Non-ProfitOrganisation , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :DataAltruismOrganisationObligation ] ;
    rdfs:label "DataAltruismOrganisation"@en ;
    rdfs:comment "A recognized non-profit body facilitating patient-consented health data donations for research."@en .

:DataAltruismOrganisationObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "DataAltruismOrganisationObligation"@en ; rdfs:comment "Regulatory transparency mandates binding altruistic networks."@en .

:DigitalHealthAuthority rdf:type owl:Class ;
    rdfs:subClassOf :Authority , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :DigitalHealthAuthorityObligation ] ;
    rdfs:label "DigitalHealthAuthority"@en ;
    rdfs:comment "The primary state agency tasked with enforcing primary use access paths and EHR compliance."@en .

:DigitalHealthAuthorityObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "DigitalHealthAuthorityObligation"@en ; rdfs:comment "Statutory reporting and auditing tasks assigned to Digital Health Authorities."@en .

:EHDSBoard rdf:type owl:Class ;
    rdfs:subClassOf :SupraNational , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :EHDSObligation ] ;
    rdfs:label "EHDSBoard"@en ;
    rdfs:comment "The Union board coordinating cross-border semantic standards and state compliance harmonization."@en .

:EHDSObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "EHDSObligation"@en ; rdfs:comment "Global mandates governing central Union management assets."@en .

:EHRSystemManufacturer rdf:type owl:Class ;
    rdfs:subClassOf :Actor , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :EHRSystemManufacturerObligation ] ;
    rdfs:label "EHRSystemManufacturer"@en ;
    rdfs:comment "An industrial developer creating Electronic Health Record systems for market placement."@en .

:EHRSystemManufacturerObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "EHRSystemManufacturerObligation"@en ; rdfs:comment "Technical documentation and certification duties binding software creators."@en .

:EHRSystemManufacturerRepresentative rdf:type owl:Class ;
    rdfs:subClassOf :Representative , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :EHRSystemManufacturerRepresentativeObligation ] ;
    rdfs:label "EHRSystemManufacturerRepresentative"@en ;
    rdfs:comment "The authorized union agent acting for a foreign software developer."@en .

:EHRSystemManufacturerRepresentativeObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "EHRSystemManufacturerRepresentativeObligation"@en ; rdfs:comment "The baseline proxy liabilities assigned to technical representatives."@en .

:EHRSystemUser rdf:type owl:Class ;
    rdfs:subClassOf :LegalEntity , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :EHRSystemUserObligation ] ;
    rdfs:label "EHRSystemUser"@en ;
    rdfs:comment "An institution or individual utilizing health data software systems in a professional framework."@en .

:EHRSystemUserObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "EHRSystemUserObligation"@en ; rdfs:comment "Logging and administrative usage constraints binding software consumers."@en .

:EHRTechnologyDistributor rdf:type owl:Class ;
    rdfs:subClassOf :Actor , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :EHRTechnologyDistributorObligation ] ;
    rdfs:label "EHRTechnologyDistributor"@en ;
    rdfs:comment "A distribution network agent making health software available on the Union market."@en .

:EHRTechnologyDistributorObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "EHRTechnologyDistributorObligation"@en ; rdfs:comment "Verification tasks linked to CE certification validation checks."@en .

:EUCommission rdf:type owl:Class ;
    rdfs:subClassOf :SupraNational , 
                    [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :EUCommissionObligation ] ,
                    [ rdf:type owl:Restriction ; owl:onProperty :hasRight ; owl:someValuesFrom :EUCommissionRight ] ;
    rdfs:label "EUCommission"@en ;
    rdfs:comment "The executive body of the European Union enforcing the execution acts of the EHDS."@en .

:EUCommissionObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "EUCommissionObligation"@en ; rdfs:comment "Implementing acts drafting timelines and gateway provisioning tasks."@en .
:EUCommissionRight rdf:type owl:Class ; rdfs:subClassOf :Right ; rdfs:label "EUCommissionRight"@en ; rdfs:comment "Entitlements allowing central compliance audits on state nodes."@en .

:GDPRSupervisoryAuthorities rdf:type owl:Class ;
    rdfs:subClassOf :Authority , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :GDPRSupervisoryAuthoritiesObligation ] ;
    rdfs:label "GDPRSupervisoryAuthorities"@en ;
    rdfs:comment "National data protection boards enforcing Regulation (EU) 2016/679 parameters within the health data environment."@en .

:GDPRSupervisoryAuthoritiesObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "GDPRSupervisoryAuthoritiesObligation"@en ; rdfs:comment "Personal data protection enforcement tasks."@en .

:HealthDataAccessBody rdf:type owl:Class ;
    rdfs:subClassOf :LegalEntity , 
                    [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :HealthDataAccessBodyObligation ] ,
                    [ rdf:type owl:Restriction ; owl:onProperty :hasRight ; owl:someValuesFrom :HealthDataAccessBodyRight ] ;
    rdfs:label "HealthDataAccessBody"@en ;
    rdfs:comment "The state organization authorized to issue secondary use health data permits."@en .

:HealthDataAccessBodyObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "HealthDataAccessBodyObligation"@en ; rdfs:comment "Mandates requiring data anonymization and secure environment logs."@en .
:HealthDataAccessBodyRight rdf:type owl:Class ; rdfs:subClassOf :Right ; rdfs:label "HealthDataAccessBodyRight"@en ; rdfs:comment "Sanctioning powers allowing fine placement on uncooperative holders."@en .

:HealthDataApplicant rdf:type owl:Class ;
    rdfs:subClassOf :HumanSubject , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :HealthDataApplicantObligation ] ;
    rdfs:label "HealthDataApplicant"@en ;
    rdfs:comment "An individual or research agent requesting data access for secondary study lines."@en .

:HealthDataApplicantObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "HealthDataApplicantObligation"@en ; rdfs:comment "Verification and ethical disclosure tracking rules."@en .

:HealthDataHolder rdf:type owl:Class ;
    rdfs:subClassOf :LegalEntity , 
                    [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :HealthDataHolderObligation ] ,
                    [ rdf:type owl:Restriction ; owl:onProperty :hasRight ; owl:someValuesFrom :HealthdataHolderRight ] ;
    rdfs:label "HealthDataHolder"@en ;
    rdfs:comment "An entity in possession of valid electronic health datasets subject to secondary reuse mandates."@en .

:HealthDataHolderObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "HealthDataHolderObligation"@en ; rdfs:comment "Duties involving the delivery of datasets to HDAB nodes."@en .

:HealthDataUser rdf:type owl:Class ;
    rdfs:subClassOf :LegalEntity , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :HealthDataUserObligation ] ;
    rdfs:label "HealthDataUser"@en ;
    rdfs:comment "A researcher or clinical agent utilizing secondary data under a formal permit."@en .

:HealthDataUserObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "HealthDataUserObligation"@en ; rdfs:comment "Public disclosure mandates regarding project outcomes."@en .

:HealthcareProfessional rdf:type owl:Class ;
    rdfs:subClassOf :Actor , [ rdf:type owl:Restriction ; owl:onProperty :hasRight ; owl:someValuesFrom :HealthcareProfessionalRight ] ;
    rdfs:label "HealthcareProfessional"@en ;
    rdfs:comment "A clinical expert authorized to manipulate patient records during healthcare delivery."@en .

:HealthcareProfessionalRight rdf:type owl:Class ; rdfs:subClassOf :Right ; rdfs:label "HealthcareProfessionalRight"@en ; rdfs:comment "Entitlements ensuring immediate file access during border treatment."@en .

:HealthcareProvider rdf:type owl:Class ;
    rdfs:subClassOf :LegalEntity , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :HealthcareProviderObligation ] ;
    rdfs:label "HealthcareProvider"@en ;
    rdfs:comment "A medical center, hospital, or clinical institution generating records."@en .

:HealthcareProviderObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "HealthcareProviderObligation"@en ; rdfs:comment "Data synchronization tasks with national infrastructures."@en .

:HealthdataHolder rdf:type owl:Class ;
    rdfs:subClassOf :HealthDataHolder ;
    rdfs:label "HealthdataHolder"@en ;
    rdfs:comment "Alternate capitalization model for data holder classes."@en .

:HealthdataHolderRight rdf:type owl:Class ; rdfs:subClassOf :Right ; rdfs:label "HealthdataHolderRight"@en ; rdfs:comment "Fees recovery rights allowed under secondary use frameworks."@en .

:LegalEntityRight rdf:type owl:Class ; rdfs:subClassOf :Right ; rdfs:label "LegalEntityRight"@en ; rdfs:comment "Corporate or institutional protections."@en .
:MSAObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "MSAObligation"@en ; rdfs:comment "Duties demanding state market monitoring logs."@en .

:MarketSurveillanceAuthority rdf:type owl:Class ;
    rdfs:subClassOf :Authority , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :MSAObligation ] ;
    rdfs:label "MarketSurveillanceAuthority"@en ;
    rdfs:comment "The state body checking that deployed health software meets CE standards."@en .

:MedicalDeviceManufacturer rdf:type owl:Class ;
    rdfs:subClassOf :Actor , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :MedicalDeviceManufacturerObligation ] ;
    rdfs:label "MedicalDeviceManufacturer"@en ;
    rdfs:comment "An engineering group creating medical hardware linked to EHR software."@en .

:MedicalDeviceManufacturerObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "MedicalDeviceManufacturerObligation"@en ; rdfs:comment "Interoperability specifications alignment tasks."@en .

:MemberState rdf:type owl:Class ;
    rdfs:subClassOf :NationalAuthority , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :MemberStateObligation ] ;
    rdfs:label "MemberState"@en ;
    rdfs:comment "An official country holding membership within the European Union."@en .

:MemberStateAffiliation rdf:type owl:Class ;
    rdfs:subClassOf :MemberState , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :MemberStateAffiliationObligation ] ;
    rdfs:label "MemberStateAffiliation"@en ;
    rdfs:comment "Sub-jurisdiction managing citizen insurance mappings."@en .

:MemberStateAffiliationObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "MemberStateAffiliationObligation"@en ; rdfs:comment "Insurance alignment processing tasks."@en .
:MemberStateObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "MemberStateObligation"@en ; rdfs:comment "National public investment and training framework updates."@en .

:MemberStateTreatment rdf:type owl:Class ;
    rdfs:subClassOf :MemberState , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :MemberStateTreatmentObligation ] ;
    rdfs:label "MemberStateTreatment"@en ;
    rdfs:comment "The state entity managing active translation matrices during patient transfer operations."@en .

:MemberStateTreatmentObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "MemberStateTreatmentObligation"@en ; rdfs:comment "Translation synchronization updates."@en .

:NationalContactPoint rdf:type owl:Class ;
    rdfs:subClassOf :NationalAuthority , [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :NationalContactPointObligation ] ;
    rdfs:label "NationalContactPoint"@en ;
    rdfs:comment "The technical network portal routing primary health summaries across borders."@en .

:NationalContactPointObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "NationalContactPointObligation"@en ; rdfs:comment "Uptime and encryption requirements for data conduits."@en .

:NaturalPerson rdf:type owl:Class ;
    rdfs:subClassOf :HumanSubject , 
                    [ rdf:type owl:Restriction ; owl:onProperty :hasObligation ; owl:someValuesFrom :NaturalPersonObligation ] ,
                    [ rdf:type owl:Restriction ; owl:onProperty :hasRight ; owl:someValuesFrom :NaturalPersonRight ] ;
    rdfs:label "NaturalPerson"@en ;
    rdfs:comment "An individual European citizen or patient inside the medical ecosystem."@en .

:NaturalPersonObligation rdf:type owl:Class ; rdfs:subClassOf :Obligation ; rdfs:label "NaturalPersonObligation"@en ; rdfs:comment "Prerequisite authentication tasks linked to portal interaction."@en .

:NaturalPersonRepresentative rdf:type owl:Class ;
    rdfs:subClassOf :Representative , [ rdf:type owl:Restriction ; owl:onProperty :hasRight ; owl:someValuesFrom :NaturalPersonRepresentativeRight ] ;
    rdfs:label "NaturalPersonRepresentative"@en ;
    rdfs:comment "A legal proxy, parent, or guardian accessing patient records."@en .

:NaturalPersonRepresentativeRight rdf:type owl:Class ; rdfs:subClassOf :Right ; rdfs:label "NaturalPersonRepresentativeRight"@en ; rdfs:comment "Proxy record download capabilities."@en .
:NaturalPersonRight rdf:type owl:Class ; rdfs:subClassOf :Right ; rdfs:label "NaturalPersonRight"@en ; rdfs:comment "Patient empowerment entitlements such as free downloads or opt-out capabilities."@en .
:NaturalPersonRightShape rdf:type owl:Class ; rdfs:label "NaturalPersonRightShape"@en ; rdfs:comment "A verification shape architecture targeting patient rights vectors."@en .

:SubmitReportActivity rdf:type owl:NamedIndividual, :Activity ;
    rdfs:label "SubmitReportActivity"@en ;
    rdfs:comment "The real-world compliance workflow task involving report delivery to state nodes."@en .

:A20 rdf:type owl:NamedIndividual, skos:Concept, :DigitalHealthAuthorityObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :DigitalHealthAuthority ;
    skos:broader :DigitalHealthAuthorityObligation ;
    skos:prefLabel "A20"@en ;
    rdfs:label "Article 20 Digital Health Authority Activity Publication Rule"@en ;
    rdfs:comment "Binds Digital Health Authorities to annual governance transparency rules."@en ;
    skos:definition "shall publish an activity report which shall contain a comprehensive overview of their activities"@en .

:A27-1 rdf:type owl:NamedIndividual, skos:Concept, :AISystemProviderObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :AISystemProvider ;
    skos:broader :AISystemProviderObligation ;
    skos:prefLabel "A27(1)"@en ;
    rdfs:label "Article 27(1) AI System Component Interoperability Mandate"@en ;
    rdfs:comment "Requires explicit compatibility proofs between health AI layers and central logging infrastructure."@en ;
    skos:definition "shall prove compliance with the requirements on the European interoperability software component for EHR systems and the European logging software component for EHR systems"@en .

:A3-2 rdf:type owl:NamedIndividual, skos:Concept, :NaturalPersonRepresentativeRight ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isHeldBy :Representative ;
    skos:broader :NaturalPersonRepresentativeRight ;
    skos:prefLabel "A3(2)"@en ;
    rdfs:label "Article 3(2) Proxy Electronic Copy Access Entitlement"@en ;
    rdfs:comment "Guarantees free-of-charge data downloads to authorized patient proxies."@en ;
    skos:definition "right to download free of charge an electronic copy of at least the personal electronic health data in the priority categories"@en .

:A34-a rdf:type owl:NamedIndividual, skos:Concept, :TechnologyImporterObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :TechnologyImporter ;
    skos:broader :TechnologyImporterObligation ;
    skos:prefLabel "A34(a)"@en ;
    rdfs:label "Article 34(a) Importer Trademark Assumption Criteria"@en ;
    rdfs:comment "Forces liability shifts when an importer places software under an private brand."@en ;
    skos:definition "shall make an EHR system, available on the market under their own name or trademark"@en .

:A34-b rdf:type owl:NamedIndividual, skos:Concept, :TechnologyImporterObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :TechnologyImporter ;
    skos:broader :TechnologyImporterObligation ;
    skos:prefLabel "A34(b)"@en ;
    rdfs:label "Article 34(b) Importer Conformity Corruption Boundary"@en ;
    rdfs:comment "Regulates post-market structural revisions introduced by third-party importing firms."@en ;
    skos:definition "shall modify an EHR system already placed on the market in such a way that conformity with the applicable requirements might be affected"@en .

:A34-c rdf:type owl:NamedIndividual, skos:Concept, :TechnologyImporterObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :TechnologyImporter ;
    skos:broader :TechnologyImporterObligation ;
    skos:prefLabel "A34(c)"@en ;
    rdfs:label "Article 34(c) Importer Intended Purpose Alteration Ban"@en ;
    rdfs:comment "Binds software purpose overrides to complete manufacturer recertification pipelines."@en ;
    skos:definition "shall modify an EHR system in such a way that it leads to changes in the intended purpose declared by the manufacturer"@en .

:A34a rdf:type owl:NamedIndividual, skos:Concept, :EHRSystemUserObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EHRSystemUser ;
    skos:broader :EHRSystemUserObligation ;
    skos:prefLabel "A34a"@en ;
    rdfs:label "Article 34a User Corporate Label Assignment Check"@en ;
    rdfs:comment "Regulates professional consumers renaming software structures internally."@en ;
    skos:definition "shall make an EHR system, available on the market under their own name or trademark"@en .

:A34b rdf:type owl:NamedIndividual, skos:Concept, :EHRSystemUserObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EHRSystemUser ;
    skos:broader :EHRSystemUserObligation ;
    skos:prefLabel "A34b"@en ;
    rdfs:label "Article 34b User Post-Market Modification Limit"@en ;
    rdfs:comment "Identifies modification steps that void baseline deployment safety profiles."@en ;
    skos:definition "shall modify an EHR system already placed on the market in such a way that conformity with the applicable requirements might be affected,"@en .

:A34c rdf:type owl:NamedIndividual, skos:Concept, :EHRSystemUserObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EHRSystemUser ;
    skos:broader :EHRSystemUserObligation ;
    skos:prefLabel "A34c"@en ;
    rdfs:label "Article 34c User Intended Purpose Deviation Check"@en ;
    rdfs:comment "Prevents hospitals from deploying diagnostic software outside explicit developer bounds."@en ;
    skos:definition "shall modify an EHR system in such a way that it leads to changes in the intended purpose declared by the manufacturer"@en .

:A44-1 rdf:type owl:NamedIndividual, skos:Concept, :EHRSystemManufacturerObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EHRSystemManufacturer ;
    skos:broader :EHRSystemManufacturerObligation ;
    skos:prefLabel "A44-1"@en ;
    rdfs:label "Article 44(1) Manufacturer Recall Cooperation Rule"@en ;
    rdfs:comment "Enforces immediate alignment when market surveillance authorities mandate software withdrawal."@en ;
    skos:definition "shall cooperate with the MSA and take measures to fix, recall, or withdraw the system if it poses risks"@en .

:A441 rdf:type owl:NamedIndividual, skos:Concept, :EHRSystemManufacturerRepresentativeObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EHRSystemManufacturerRepresentative ;
    skos:broader :EHRSystemManufacturerRepresentativeObligation ;
    skos:prefLabel "A44(1)"@en ;
    rdfs:label "Article 44(1) Representative Emergency Intervention Duty"@en ;
    rdfs:comment "Extends recall liability directly to proxy agents inside the EU border."@en ;
    skos:definition "shall cooperate with the MSA and take measures to fix, recall, or withdraw the system if it poses risks"@en .

:A45-1 rdf:type owl:NamedIndividual, skos:Concept, :EHRSystemManufacturerObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EHRSystemManufacturer ;
    skos:broader :EHRSystemManufacturerObligation ;
    skos:prefLabel "A45(1)"@en ;
    rdfs:label "Article 45(1) Manufacturer Corrective Action Directive"@en ;
    rdfs:comment "Demands proactive software patching when compliance failures emerge post-deployment."@en ;
    skos:definition "shall, take adequate corrective action to bring the EHR system into conformity"@en .

:A3-1 rdf:type owl:NamedIndividual, skos:Concept, :NaturalPersonRight ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isHeldBy :NaturalPerson ;
    skos:broader :NaturalPersonRight ;
    skos:prefLabel "A3(1)"@en ;
    rdfs:label "Article 3(1) Core Healthcare Primary Data Access Path"@en ;
    rdfs:comment "Guarantees digital access vectors to patients checking their medical charts."@en ;
    skos:definition "processed for the provision of healthcare through the electronic health data access services,"@en .

:A30-1-a rdf:type owl:NamedIndividual, skos:Concept, :EHRSystemManufacturerObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EHRSystemManufacturer ;
    skos:broader :EHRSystemManufacturerObligation ;
    skos:prefLabel "A30(1)(a)"@en ;
    rdfs:label "Article 30(1)(a) Harmonised Component Essential Requirement Mandate"@en ;
    rdfs:comment "Forces core compliance with uniform European interoperability criteria."@en ;
    skos:definition "shall ensure that the harmonised software components of their EHR systems and the EHR systems themselves, are in conformity with the essential requirements"@en .

:A30-1-b rdf:type owl:NamedIndividual, skos:Concept, :EHRSystemManufacturerObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EHRSystemManufacturer ;
    skos:broader :EHRSystemManufacturerObligation ;
    skos:prefLabel "A30(1)(b)"@en ;
    rdfs:label "Article 30(1)(b) Component Contamination Prevention Rule"@en ;
    rdfs:comment "Prevents ancillary code assets from breaking the functionality of verified exchange layers."@en ;
    skos:definition "shall ensure that the harmonised software components of their EHR systems are not adversely affected by other software components of the same EHR system,"@en .

:A32-8-1 rdf:type owl:NamedIndividual, skos:Concept, :TechnologyImporterObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :TechnologyImporter ;
    skos:broader :TechnologyImporterObligation ;
    skos:prefLabel "A32(8.1)"@en ;
    rdfs:label "Article 32(8.1) Importer Complaint Ledger Rule"@en ;
    rdfs:comment "Requires structural recording of external market failures by importing bodies."@en ;
    skos:definition "shall keep a register of complaints of non-conforming EHR systems and EHR system recalls and withdrawals"@en .

:A32-9 rdf:type owl:NamedIndividual, skos:Concept, :TechnologyImporterObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :TechnologyImporter ;
    skos:broader :TechnologyImporterObligation ;
    skos:prefLabel "A32(9)"@en ;
    rdfs:label "Article 32(9) Importer Incident Investigation Rule"@en ;
    rdfs:comment "Demands formal investigation workflows when software failures threaten patient metrics."@en ;
    skos:definition "shall investigate complaints and follow up on information received on incidents involving an EHR system"@en .

:A32-9-1 rdf:type owl:NamedIndividual, skos:Concept, :TechnologyImporterObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :TechnologyImporter ;
    skos:broader :TechnologyImporterObligation ;
    skos:prefLabel "A32(9.1)"@en ;
    rdfs:label "Article 32(9.1) Importer Corrective Matrix Logging Mandate"@en ;
    rdfs:comment "Binds incident responses to auditable documentation records."@en ;
    skos:definition "shall register those complaints, any recalls or withdrawals of EHR systems and any corrective measure taken to bring the EHR system into conformity"@en .

:A32-9-2 rdf:type owl:NamedIndividual, skos:Concept, :TechnologyImporterObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :TechnologyImporter ;
    skos:broader :TechnologyImporterObligation ;
    skos:prefLabel "A32(9.2)"@en ;
    rdfs:label "Article 32(9.2) Importer Supply Chain Notification Mandate"@en ;
    rdfs:comment "Requires downstream and upstream communication across the medical deployment pipeline."@en ;
    skos:definition "shall keep the manufacturer, distributors and, where relevant, authorised representatives informed in a timely manner of the investigation and follow-up carried out"@en .

:A45-2 rdf:type owl:NamedIndividual, skos:Concept, :MSAObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :MarketSurveillanceAuthority ;
    skos:broader :MSAObligation ;
    skos:prefLabel "A45(2)"@en ;
    rdfs:label "Article 45(2) MSA Provisional Measure Notification Rule"@en ;
    rdfs:comment "Forces state enforcement boards to inform central Union layers regarding local software bans."@en ;
    skos:definition "shall inform the Commission and the other Member States’ market surveillance authorities, without delay, of provisional measures taken"@en .

:A45-2-a-b rdf:type owl:NamedIndividual, skos:Concept, :MSAObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :MarketSurveillanceAuthority ;
    skos:broader :MSAObligation ;
    skos:prefLabel "A45(2)(a)(b)"@en ;
    rdfs:label "Article 45(2)(a)(b) Non-Compliance Vector Specification Rule"@en ;
    rdfs:comment "Requires technical error deconstruction within state notice channels."@en ;
    skos:definition "shall indicate the system non-compliance"@en .

:A45-3 rdf:type owl:NamedIndividual, skos:Concept, :MSAObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :MarketSurveillanceAuthority ;
    skos:broader :MSAObligation ;
    skos:prefLabel "A45(3)"@en ;
    rdfs:label "Article 45(3) MSA Definitive Measure Shared Disclosure Rule"@en ;
    rdfs:comment "Synchronizes absolute market interventions across all EU nations."@en ;
    skos:definition "shall inform the Commission and the other market surveillance authorities of any measures adopted"@en .

:A58-1-g rdf:type owl:NamedIndividual, skos:Concept, :HealthDataAccessBodyObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :HealthDataAccessBody ;
    skos:broader :HealthDataAccessBodyObligation ;
    skos:prefLabel "A58(1)(g)"@en ;
    rdfs:label "Article 58(1)(g) HDAB Secondary Project Outcome Publication Rule"@en ;
    rdfs:comment "Enforces public scientific transparency by showing research results on public portals."@en ;
    skos:definition "shall make information available on the results or outcomes of the projects for which the electronic health data were used"@en .

:A58-2 rdf:type owl:NamedIndividual, skos:Concept, :HealthDataAccessBodyObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :HealthDataAccessBody ;
    skos:broader :HealthDataAccessBodyObligation ;
    skos:prefLabel "A58(2)"@en ;
    rdfs:label "Article 58(2) HDAB Opt-Out Procedure Provision Mandate"@en ;
    rdfs:comment "Requires HDAB nodes to present accessible mechanisms for patient secondary use data exceptions."@en ;
    skos:definition "shall provide public information about the procedure to opt out and facilitate the exercise of that right"@en .

:A63-8 rdf:type owl:NamedIndividual, skos:Concept, :EUCommissionObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EUCommission ;
    skos:broader :EUCommissionObligation ;
    skos:prefLabel "A63(8)"@en ;
    rdfs:label "Article 63(8) Commission Enforcement Harmonisation Guideline Mandate"@en ;
    rdfs:comment "Demands close technical integration with the Board before fine matrices are distributed."@en ;
    skos:definition "shall issue guidelines, in close cooperation with the EHDS Board, on enforcement measures"@en .

:A7-1 rdf:type owl:NamedIndividual, skos:Concept, :NaturalPersonRight ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isHeldBy :NaturalPerson ;
    skos:broader :NaturalPersonRight ;
    skos:prefLabel "A7(1)"@en ;
    rdfs:label "Article 7(1) Patient Immediate Provider Transfer Entitlement"@en ;
    rdfs:comment "Prevents data vendor lock-in by guaranteeing portability paths."@en ;
    skos:definition "provider of their choice immediately"@en .

:A7-2 rdf:type owl:NamedIndividual, skos:Concept, :NaturalPersonRight ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isHeldBy :NaturalPerson ;
    skos:broader :NaturalPersonRight ;
    skos:prefLabel "A7(2)"@en ;
    rdfs:label "Article 7(2) European Exchange Format Download Right"@en ;
    rdfs:comment "Guarantees that files match European exchange matrices exactly."@en ;
    skos:definition "right to request the transmission of their personal electronic health data in the European electronic health record exchange format"@en .

:A7-3 rdf:type owl:NamedIndividual, skos:Concept, :NaturalPersonRight ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isHeldBy :NaturalPerson ;
    skos:broader :NaturalPersonRight ;
    skos:prefLabel "A7(3)"@en ;
    rdfs:label "Article 7(3) Targeted Multi-Party Transmission Right"@en ;
    rdfs:comment "Empowers patients to command instant data transfers to external destinations."@en ;
    skos:definition "right to request a healthcare provider to transmit a part of their personal electronic health data to a clearly identified recipient"@en .

:A83-1 rdf:type owl:NamedIndividual, skos:Concept, :MemberStateObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :MemberState ;
    skos:broader :MemberStateObligation ;
    skos:prefLabel "A83(1)"@en ;
    rdfs:label "Article 83(1) State Professional Training Investment Rule"@en ;
    rdfs:comment "Forces state frameworks to embed digital path instruction inside medical schools."@en ;
    skos:definition "shall develop and implement or provide access to training programmes for health professionals"@en .

:A83-1-1 rdf:type owl:NamedIndividual, skos:Concept, :MemberStateObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :MemberState ;
    skos:broader :MemberStateObligation ;
    skos:prefLabel "A83(1.1)"@en ;
    rdfs:label "Article 83(1.1) State Professional Information Access Requirement"@en ;
    rdfs:comment "Requires ongoing dissemination of digital liability bounds to practitioners."@en ;
    skos:definition "shall provide access to information for health professionals in order for them to understand and effectively carry out their role"@en .

:A84-1 rdf:type owl:NamedIndividual, skos:Concept, :MemberStateObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :MemberState ;
    skos:broader :MemberStateObligation ;
    skos:prefLabel "A84(1)"@en ;
    rdfs:label "Article 84(1) State Patient Digital Literacy Mandate"@en ;
    rdfs:comment "Requires structural educational investment supporting data portal usage by individuals."@en ;
    skos:definition "shall promote and support digital health literacy for the development of relevant competences and skills for patients"@en .

:A84-1-1 rdf:type owl:NamedIndividual, skos:Concept, :MemberStateObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :MemberState ;
    skos:broader :MemberStateObligation ;
    skos:prefLabel "A84(1.1)"@en ;
    rdfs:label "Article 84(1.1) State Public Awareness Campaign Directive"@en ;
    rdfs:comment "Demands active public campaign frameworks to inform data subjects of access paths."@en ;
    skos:definition "shall promote awareness-raising campaigns or programmes to inform patients and the public at large"@en .

:A10-1 rdf:type owl:NamedIndividual, skos:Concept, :NaturalPersonRight ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isHeldBy :NaturalPerson ;
    skos:broader :NaturalPersonRight ;
    skos:prefLabel "A10(1)"@en ;
    rdfs:label "Article 10(1) Patient Self-Insertion Content Right"@en ;
    rdfs:comment "Guarantees validation vectors for citizen-entered records inside state hubs."@en ;
    skos:definition "Right to insert data into their own EHR or have it inserted via patient portals."@en .

:A12-2 rdf:type owl:NamedIndividual, skos:Concept, :EHRSystemUserObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EHRSystemUser ;
    skos:broader :EHRSystemUserObligation ;
    skos:prefLabel "A12(2)"@en ;
    rdfs:label "Article 12(2) User Cross-Border Immediate Accessibility Mandate"@en ;
    rdfs:comment "Forces clinical deployment hubs to permit cross-border incoming record processing."@en ;
    skos:definition "Shall ensure that healthcare professionals have immediate access to electronic health records in cross-border contexts."@en .

:A14-3 rdf:type owl:NamedIndividual, skos:Concept, :HealthcareProviderObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :HealthcareProvider ;
    skos:broader :HealthcareProviderObligation ;
    skos:prefLabel "A14(3)"@en ;
    rdfs:label "Article 14(3) Provider Electronic Sharing Receipt Requirement"@en ;
    rdfs:comment "Secures automated auditing trace matrices by enforcing digital receipt generation."@en ;
    skos:definition "Shall issue an electronic receipt or confirmation whenever patient data is shared or transmitted to external parties."@en .

:A22-1 rdf:type owl:NamedIndividual, skos:Concept, :EHRSystemManufacturerObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EHRSystemManufacturer ;
    skos:broader :EHRSystemManufacturerObligation ;
    skos:prefLabel "A22(1)"@en ;
    rdfs:label "Article 22(1) Manufacturer Pre-Market Technical Documentation Mandate"@en ;
    rdfs:comment "Forces absolute validation of design records before software goes live."@en ;
    skos:definition "Shall draw up the technical documentation before placing an EHR system on the market."@en .

:A23-4 rdf:type owl:NamedIndividual, skos:Concept, :EHRSystemManufacturerObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EHRSystemManufacturer ;
    skos:broader :EHRSystemManufacturerObligation ;
    skos:prefLabel "A23(4)"@en ;
    rdfs:label "Article 23(4) Manufacturer 10-Year Record Retention Constraint"@en ;
    rdfs:comment "Establishes a firm temporal constraint on documentation shelf life."@en ;
    skos:definition "Shall retain the EU declaration of conformity and technical documentation for 10 years after the EHR system has been placed on the market."@en .

:A25-2 rdf:type owl:NamedIndividual, skos:Concept, :EHRTechnologyDistributorObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EHRTechnologyDistributor ;
    skos:broader :EHRTechnologyDistributorObligation ;
    skos:prefLabel "A25(2)"@en ;
    rdfs:label "Article 25(2) Distributor CE Mark Verification Check"@en ;
    rdfs:comment "Enforces gatekeeping liabilities on distributors checking entry parameters."@en ;
    skos:definition "Shall verify that the EHR system bears the mandatory CE marking before making it available."@en .

:A31-1 rdf:type owl:NamedIndividual, skos:Concept, :MedicalDeviceManufacturerObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :MedicalDeviceManufacturer ;
    skos:broader :MedicalDeviceManufacturerObligation ;
    skos:prefLabel "A31(1)"@en ;
    rdfs:label "Article 31(1) Medical Device MDR Alignment Mandate"@en ;
    rdfs:comment "Links the EHDS framework directly to pre-existing Regulation (EU) 2017/745 safety perimeters."@en ;
    skos:definition "Shall ensure full alignment with both the EHDS interoperability specifications and Medical Device Regulation (MDR) safety criteria."@en .

:A33-1 rdf:type owl:NamedIndividual, skos:Concept, :HealthDataHolderObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :HealthDataHolder ;
    skos:broader :HealthDataHolderObligation ;
    skos:prefLabel "A33(1)"@en ;
    rdfs:label "Article 33(1) Holder Secondary Dataset Delivery Mandate"@en ;
    rdfs:comment "Voids proprietary data silos by forcing transfers to HDAB structural pipelines."@en ;
    skos:definition "Shall make electronic health data available for secondary use categories to the health data access bodies."@en .

:A35-2-b rdf:type owl:NamedIndividual, skos:Concept, :HealthDataHolderObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :HealthDataHolder ;
    skos:broader :HealthDataHolderObligation ;
    skos:prefLabel "A35(2)(b)"@en ;
    rdfs:label "Article 35(2)(b) Holder 15-Day Update Constraint"@en ;
    rdfs:comment "Establishes a clear legislative window for processing data availability shifts."@en ;
    skos:definition "Shall notify the health data access body of any data availability changes within 15 days."@en .

:A36-1 rdf:type owl:NamedIndividual, skos:Concept, :HealthDataUserObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :HealthDataUser ;
    skos:broader :HealthDataUserObligation ;
    skos:prefLabel "A36(1)"@en ;
    rdfs:label "Article 36(1) User Formal Data Permit Application Mandate"@en ;
    rdfs:comment "Prerequisite regulatory hurdle before any secondary processing task occurs."@en ;
    skos:definition "Shall submit an application for a health data permit to the health data access body."@en .

:A37-4 rdf:type owl:NamedIndividual, skos:Concept, :HealthDataUserObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :HealthDataUser ;
    skos:broader :HealthDataUserObligation ;
    skos:prefLabel "A37(4)"@en ;
    rdfs:label "Article 37(4) User Secure Processing Environment Bound"@en ;
    rdfs:comment "Enforces absolute spatial isolation on active research dataset computations."@en ;
    skos:definition "Shall only handle and process the provided datasets within a secure, isolated processing environment."@en .

:A39-1-a rdf:type owl:NamedIndividual, skos:Concept, :HealthDataUserObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :HealthDataUser ;
    skos:broader :HealthDataUserObligation ;
    skos:prefLabel "A39(1)(a)"@en ;
    rdfs:label "Article 39(1)(a) User Public Outcome Disclosure Mandate"@en ;
    rdfs:comment "Blocks data hoarding by requiring open dissemination of research insights."@en ;
    skos:definition "Shall publicly log and disclose all research findings or health analytics outcomes derived from secondary datasets."@en .

:A41-3 rdf:type owl:NamedIndividual, skos:Concept, :DataAltruismOrganisationObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :DataAltruismOrganisation ;
    skos:broader :DataAltruismOrganisationObligation ;
    skos:prefLabel "A41(3)"@en ;
    rdfs:label "Article 41(3) Altruism Framework Transparency Mandate"@en ;
    rdfs:comment "Requires absolute documentation tracking for donated citizen files."@en ;
    skos:definition "Shall maintain strict operational transparency and granular consent maps for data collected via altruistic mechanisms."@en .

:A46-2 rdf:type owl:NamedIndividual, skos:Concept, :HealthDataAccessBodyRight ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isHeldBy :HealthDataAccessBody ;
    skos:broader :HealthDataAccessBodyRight ;
    skos:prefLabel "A46(2)"@en ;
    rdfs:label "Article 46(2) HDAB Statutory Sanctioning Entitlement"@en ;
    rdfs:comment "Authorizes administrative fines to penalize corporate withholding tactics."@en ;
    skos:definition "Right to issue legally binding administrative fines to health data holders who refuse to supply mandatory datasets."@en .

:A49-1 rdf:type owl:NamedIndividual, skos:Concept, :HealthDataAccessBodyObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :HealthDataAccessBody ;
    skos:broader :HealthDataAccessBodyObligation ;
    skos:prefLabel "A49(1)"@en ;
    rdfs:label "Article 49(1) HDAB 2-Month Permit Determination Constraint"@en ;
    rdfs:comment "Prevents bureaucratical research delays by enforcing response ceilings."@en ;
    skos:definition "Shall issue or refuse a health data permit within a fixed, non-extendable legislative window of 2 months."@en .

:A51-5 rdf:type owl:NamedIndividual, skos:Concept, :HealthDataAccessBodyObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :HealthDataAccessBody ;
    skos:broader :HealthDataAccessBodyObligation ;
    skos:prefLabel "A51(5)"@en ;
    rdfs:label "Article 51(5) HDAB Pseudonymisation Payload Pre-Requisite"@en ;
    rdfs:comment "Forces technical data modification steps before files hit external researchers."@en ;
    skos:definition "Shall ensure that the data transmission payload is completely pseudonymised or anonymised prior to secure environment placement."@en .

:A54-2 rdf:type owl:NamedIndividual, skos:Concept, :NationalContactPointObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :NationalContactPoint ;
    skos:broader :NationalContactPointObligation ;
    skos:prefLabel "A54(2)"@en ;
    rdfs:label "Article 54(2) NCP MyHealth@EU Interface Mandate"@en ;
    rdfs:comment "Forces state conduits to bridge cleanly with Union communications nodes."@en ;
    skos:definition "Shall act as a secure technical gateway connecting national digital infrastructures to the cross-border MyHealth@EU system."@en .

:A60-1 rdf:type owl:NamedIndividual, skos:Concept, :EHDSObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EHDSBoard ;
    skos:broader :EHDSObligation ;
    skos:prefLabel "A60(1)"@en ;
    rdfs:label "Article 60(1) Board State Best-Practice Coordination Task"@en ;
    rdfs:comment "Establishes institutional meeting structures for national health authorities."@en ;
    skos:definition "Shall facilitate cooperation and exchange of best practices between Member State digital health authorities."@en .

:A62-3 rdf:type owl:NamedIndividual, skos:Concept, :EHDSObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EHDSBoard ;
    skos:broader :EHDSObligation ;
    skos:prefLabel "A62(3)"@en ;
    rdfs:label "Article 62(3) Board Technical Gateway Formal Opinion Duty"@en ;
    rdfs:comment "Mandates ongoing structural feedback on core interoperability updates."@en ;
    skos:definition "Shall issue formal opinions on technical specifications, cross-border interoperability gateways, and unified security baselines."@en .

:A66-1 rdf:type owl:NamedIndividual, skos:Concept, :GDPRSupervisoryAuthoritiesObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :GDPRSupervisoryAuthorities ;
    skos:broader :GDPRSupervisoryAuthoritiesObligation ;
    skos:prefLabel "A66(1)"@en ;
    rdfs:label "Article 66(1) Data Protection Board Jurisdictional Isolation Rule"@en ;
    rdfs:comment "Prevents EHDS bodies from overstepping baseline state privacy board powers."@en ;
    skos:definition "Shall remain solely responsible for auditing and enforcing personal data processing compliance under GDPR bounds within the EHDS."@en .

:A72-1 rdf:type owl:NamedIndividual, skos:Concept, :MemberStateAffiliationObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :MemberStateAffiliation ;
    skos:broader :MemberStateObligation ;
    skos:prefLabel "A72(1)"@en ;
    rdfs:label "Article 72(1) Insurance Matrix Entitlement Validation Rule"@en ;
    rdfs:comment "Forces state health insurance files to support real-time cross-border calls."@en ;
    skos:definition "Shall formally connect national health insurance registries to ensure cross-border entitlement validation."@en .

:A78-3 rdf:type owl:NamedIndividual, skos:Concept, :MemberStateTreatmentObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :MemberStateTreatment ;
    skos:broader :MemberStateObligation ;
    skos:prefLabel "A78(3)"@en ;
    rdfs:label "Article 78(3) State Summary Medical Translation Alignment Rule"@en ;
    rdfs:comment "Secures medical data semantics when treating foreign travelers."@en ;
    skos:definition "Shall harmonize medical translation matrices to permit error-free electronic patient summary transfers."@en .

:A82-4 rdf:type owl:NamedIndividual, skos:Concept, :HealthcareProfessionalRight ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isHeldBy :HealthcareProfessional ;
    skos:broader :HealthcareProfessionalRight ;
    skos:prefLabel "A82(4)"@en ;
    rdfs:label "Article 82(4) Practitioner Emergency Translation Overrule Entitlement"@en ;
    rdfs:comment "Authorizes immediate clinician access to translated records in life-support events."@en ;
    skos:definition "Right to access translation-supported patient files when treating an emergency cross-border citizen."@en .

:A85-2 rdf:type owl:NamedIndividual, skos:Concept, :EUCommissionRight ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isHeldBy :EUCommission ;
    skos:broader :EUCommissionRight ;
    skos:prefLabel "A85(2)"@en ;
    rdfs:label "Article 85(2) Commission Infrastructure Spot-Audit Right"@en ;
    rdfs:comment "Gives the Commission the power to inspect weak or failing national data hubs."@en ;
    skos:definition "Right to conduct technical compliance spot-audits on national infrastructures feeding central European semantic hubs."@en .

:A87-1 rdf:type owl:NamedIndividual, skos:Concept, :HealthDataAccessBodyObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :HealthDataAccessBody ;
    skos:broader :HealthDataAccessBodyObligation ;
    skos:prefLabel "A87(1)"@en ;
    rdfs:label "Article 87(1) European Sovereign Data Processing Boundary Mandate"@en ;
    rdfs:comment "Restricts primary modification and translation storage strictly inside Union sovereign regions."@en ;
    skos:definition "Shall store and process personal electronic health data in the Union when performing pseudonymisation, anonymisation and any other personal data processing operations."@en .

:A91-3 rdf:type owl:NamedIndividual, skos:Concept, :HealthDataAccessBodyObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :HealthDataAccessBody ;
    skos:broader :HealthDataAccessBodyObligation ;
    skos:prefLabel "A91(3)"@en ;
    rdfs:label "Article 91(3) Third Country Equivalence Tracking Mandate"@en ;
    rdfs:comment "Demands checking external legal frameworks before authorizing data exports."@en ;
    skos:definition "Shall monitor developments in third countries and international organisations that could affect the application of the implementing acts adopted."@en .

:A96-3 rdf:type owl:NamedIndividual, skos:Concept, :EUCommissionObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EUCommission ;
    skos:broader :EUCommissionObligation ;
    skos:prefLabel "A96(3)"@en ;
    rdfs:label "Article 96(3) Secondary Processing Environment Execution Blueprint Rule"@en ;
    rdfs:comment "Directs the Commission to establish standard parameters for secure computing nodes."@en ;
    skos:definition "Shall adopt implementing acts to lay down the detailed technical requirements for the secondary use secure processing environment."@en .

:A96-9-d rdf:type owl:NamedIndividual, skos:Concept, :EUCommissionObligation ;
    skos:inScheme <https://w3id.org/ehds/ontology> ;
    :isAssignedTo :EUCommission ;
    skos:broader :EUCommissionObligation ;
    skos:prefLabel "A96(9)(d)"@en ;
    rdfs:label "Article 96(9)(d) Commission Supplementary Grid Delivery Mandate"@en ;
    rdfs:comment "Requires fallback central computing architecture availability to guarantee European semantic connectivity."@en ;
    skos:definition "shall provide supplementary cross-border digital health services and infrastructures"@en .

skos:ConceptScheme rdf:type owl:Class ;
    rdfs:label "ConceptScheme"@en ;
    rdfs:comment "A logical taxonomy grouping structural concepts under a single terminology namespace."@en .

owl:Ontology rdf:type owl:Class ;
    rdfs:label "Ontology"@en ;
    rdfs:comment "A semantic data structure declaring real-world classes, constraints, and relationships."@en .

owl:NamedIndividual rdf:type owl:Class ;
    rdfs:label "NamedIndividual"@en ;
    rdfs:comment "A concrete instance or distinct asset point mapped inside class constraints."@en .